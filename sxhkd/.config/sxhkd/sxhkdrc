alt + Return
    alacritty

alt + d
    rofi -modi drun -show drun

alt + b
    rofi-bluetooth

alt + i
    firefox

alt + I
    brave --incognito

alt + n
    firefox netflix.com

alt + e
    nvim-qt --no-ext-tabline --no-ext-popupmenu --fullscreen

alt + q
    qutebrowser

alt + v
    vivaldi-stable

XF86AudioRaiseVolume
    pamixer -i 5 && volnoti-show $(pamixer --get-volume)

XF86AudioLowerVolume
    pamixer -d 5 && volnoti-show $(pamixer --get-volume)

XF86MonBrightnessUp
    light -A 10

XF86MonBrightnessDown
    light -U 10

alt + w
    feh --randomize --bg-fill ~/wallpapers/*

alt + T
    surf tradingview.com

alt + P
    surf phemex.com/trade

alt + s
    tabbed surf -pe
