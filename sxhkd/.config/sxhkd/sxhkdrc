alt + Return
    st

alt + d
    rofi -modi drun -show drun

alt + shift + b
    blueman-manager

alt + i
    librewolf

alt + I
    librewolf --private-window

alt + e
    nvim-qt --no-ext-tabline --no-ext-popupmenu --fullscreen

alt + q
    qutebrowser

XF86AudioRaiseVolume
    pamixer -i 5 && volnoti-show $(pamixer --get-volume)

XF86AudioLowerVolume
    pamixer -d 5 && volnoti-show $(pamixer --get-volume)

XF86MonBrightnessUp
    light -A 10

XF86MonBrightnessDown
    light -U 10

alt + w
    feh --randomize --bg-fill ~/wallpapers/*

